{
    "name": "xiaozhi-client",
    "version": "1.0.0",
    "description": "Node.js小智客户端",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "bun --hot index.js",
        "test": "bun --hot test.js",
        "devices": "bun --hot devices.js --menu",
        "build": "bun build index.js --target=node --compile --minify --outfile ./build/xiaozhi  --external=shelljs"
    },
    "keywords": [
        "device",
        "activation",
        "iot",
        "authentication",
        "hmac",
        "fingerprint"
    ],
    "author": "shadow",
    "license": "MIT",
    "dependencies": {
        "audify": "^1.9.0",
        "axios": "^1.6.0",
        "ws": "^8.18.2"
    },
    "optionalDependencies": {
        "open": "^9.1.0"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/your-username/device-activator.git"
    },
    "bugs": {
        "url": "https://github.com/your-username/device-activator/issues"
    },
    "homepage": "https://github.com/your-username/device-activator#readme"
}
